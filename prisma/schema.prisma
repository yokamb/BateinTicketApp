// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  CUSTOMER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// NextAuth Required Models
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          String    @default("ADMIN")
  plan          String    @default("FREE")
  paypalSubscriptionId String?
  razorpaySubscriptionId String?
  razorpayPaymentId     String?
  additionalStorageGB   Int       @default(0)
  
  accounts      Account[]
  sessions      Session[]

  // SaaS Relations
  professionalRole String?
  
  workspacesOwned Workspace[]    @relation("WorkspaceAdmin")
  workspaces      InstanceAccess[]
  ticketsCreated  Ticket[]       @relation("TicketCreator")
  comments        Comment[]
  notePagesCreated NotePage[]
  
  profile       UserProfile?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// SaaS Specific Models
model Workspace {
  id          String   @id @default(cuid())
  name        String
  adminId     String
  admin       User     @relation("WorkspaceAdmin", fields: [adminId], references: [id], onDelete: Cascade)
  requiresChangeApproval Boolean @default(false)
  
  customers   InstanceAccess[]
  tickets     Ticket[]
  ticketTypes TicketType[]
  invites     WorkspaceInvite[]
  noteSections NoteSection[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model InstanceAccess {
  workspaceId String
  userId      String
  role        String   @default("MEMBER") // ADMIN, MEMBER, GUEST

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([workspaceId, userId])
}

model WorkspaceInvite {
  id          String   @id @default(cuid())
  email       String
  workspaceId String
  role        String   @default("GUEST")
  token       String   @unique
  expiresAt   DateTime
  
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([workspaceId, email])
}

model Ticket {
  id          String         @id @default(cuid())
  shortId     String
  title       String
  description String
  type        String         @default("INCIDENT")
  typeCategory String        @default("ISSUE")
  status      String         @default("OPEN")
  priority    String         @default("MEDIUM")
  
  approverId  String?
  approvalStatus String      @default("PENDING")
  rejectionFeedback String?

  workspaceId String
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  creatorId   String
  creator     User           @relation("TicketCreator", fields: [creatorId], references: [id])
  
  attachments Attachment[]
  comments    Comment[]
  
  // Self relation for interlinking
  linkedFrom  TicketLink[]   @relation("LinkedFrom")
  linkedTo    TicketLink[]   @relation("LinkedTo")

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model TicketType {
  id          String   @id @default(cuid())
  label       String
  category    String   // ISSUE, REQUEST, CHANGE
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([workspaceId, label])
}

model TicketLink {
  sourceId String
  targetId String

  source   Ticket @relation("LinkedFrom", fields: [sourceId], references: [id], onDelete: Cascade)
  target   Ticket @relation("LinkedTo", fields: [targetId], references: [id], onDelete: Cascade)

  @@id([sourceId, targetId])
}

model Attachment {
  id        String   @id @default(cuid())
  fileUrl   String
  size      BigInt   @default(0)
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
}

model Comment {
  id        String   @id @default(cuid())
  text      String
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NoteSection {
  id          String   @id @default(cuid())
  name        String
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  pages       NotePage[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model NotePage {
  id          String      @id @default(cuid())
  title       String
  content     String?
  sectionId   String
  section     NoteSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  
  creatorId   String
  creator     User        @relation(fields: [creatorId], references: [id])

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model UserProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role          String?
  subSpecialty  String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model RoleConfig {
  id           String   @id @default(cuid())
  roleName     String   @unique
  issueLabel   String
  requestLabel String
  changeLabel  String
  issueIcon    String
  requestIcon  String
  changeIcon   String
  colorScheme  String   // Comma-separated hex colors

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

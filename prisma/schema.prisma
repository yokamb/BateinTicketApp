// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  CUSTOMER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// NextAuth Required Models
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          String    @default("CUSTOMER")
  plan          String    @default("FREE")
  paypalSubscriptionId String?
  additionalStorageGB   Int       @default(0)
  
  accounts      Account[]
  sessions      Session[]

  // SaaS Relations
  workspacesOwned Workspace[]    @relation("WorkspaceAdmin")
  workspaces      InstanceAccess[]
  ticketsCreated  Ticket[]       @relation("TicketCreator")
  comments        Comment[]
  approverRoles   WorkspaceApprover[]
  notePagesCreated NotePage[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// SaaS Specific Models
model Workspace {
  id          String   @id @default(cuid())
  name        String
  adminId     String
  admin       User     @relation("WorkspaceAdmin", fields: [adminId], references: [id], onDelete: Cascade)
  requiresChangeApproval Boolean @default(false)
  
  customers   InstanceAccess[]
  approvers   WorkspaceApprover[]
  tickets     Ticket[]
  noteSections NoteSection[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model InstanceAccess {
  workspaceId String
  userId      String

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([workspaceId, userId])
}

model WorkspaceApprover {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

model Ticket {
  id          String         @id @default(cuid())
  shortId     String
  title       String
  description String
  type        String         @default("INCIDENT")
  status      String         @default("OPEN")
  priority    String         @default("MEDIUM")
  
  approverId  String?
  approvalStatus String      @default("PENDING")

  workspaceId String
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  creatorId   String
  creator     User           @relation("TicketCreator", fields: [creatorId], references: [id])
  
  attachments Attachment[]
  comments    Comment[]
  
  // Self relation for interlinking
  linkedFrom  TicketLink[]   @relation("LinkedFrom")
  linkedTo    TicketLink[]   @relation("LinkedTo")

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model TicketLink {
  sourceId String
  targetId String

  source   Ticket @relation("LinkedFrom", fields: [sourceId], references: [id], onDelete: Cascade)
  target   Ticket @relation("LinkedTo", fields: [targetId], references: [id], onDelete: Cascade)

  @@id([sourceId, targetId])
}

model Attachment {
  id        String   @id @default(cuid())
  fileUrl   String
  size      BigInt   @default(0)
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
}

model Comment {
  id        String   @id @default(cuid())
  text      String
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NoteSection {
  id          String   @id @default(cuid())
  name        String
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  pages       NotePage[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model NotePage {
  id          String      @id @default(cuid())
  title       String
  content     String?
  sectionId   String
  section     NoteSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  
  creatorId   String
  creator     User        @relation(fields: [creatorId], references: [id])

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}
